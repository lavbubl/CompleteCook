global.bindslist[INPUTS.left]			= [global.keybinds.left,		gp_padl] //replace the controller section with global.gamepadbinds.#
global.bindslist[INPUTS.right]			= [global.keybinds.right,		gp_padr]
global.bindslist[INPUTS.up]				= [global.keybinds.up,			gp_padu]
global.bindslist[INPUTS.down]			= [global.keybinds.down,		gp_padd]
global.bindslist[INPUTS.dash]			= [global.keybinds.dash,		[gp_shoulderrb, gp_shoulderr]]
global.bindslist[INPUTS.jump]			= [global.keybinds.jump,		gp_face1]
global.bindslist[INPUTS.grab]			= [global.keybinds.grab,		gp_face3]
global.bindslist[INPUTS.taunt]			= [global.keybinds.taunt,		gp_face4]
global.bindslist[INPUTS.superjump]		= [global.keybinds.superjump,	vk_nokey]
global.bindslist[INPUTS.groundpound]	= [global.keybinds.groundpound, vk_nokey]
global.bindslist[INPUTS.ui_left]		= [global.keybinds.ui_left,		gp_padl]
global.bindslist[INPUTS.ui_right]		= [global.keybinds.ui_right,	gp_padr]
global.bindslist[INPUTS.ui_up]			= [global.keybinds.ui_up,		gp_padu]
global.bindslist[INPUTS.ui_down]		= [global.keybinds.ui_down,		gp_padd]
global.bindslist[INPUTS.ui_accept]		= [global.keybinds.ui_accept,	[gp_face1, gp_start]]
global.bindslist[INPUTS.ui_deny]		= [global.keybinds.ui_deny,		gp_face3]
